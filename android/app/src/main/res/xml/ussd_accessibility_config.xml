<?xml version="1.0" encoding="utf-8"?>
<!--
    Accessibility Service configuration for EthioStat USSD popup reader.

    Scope: Phone/dialer packages that host the USSD popup dialog or the dialpad.
      - com.android.phone           : AOSP telephony — hosts the USSD result dialog
      - com.samsung.telephony.phone : Samsung telephony (One UI) — same role
      - com.samsung.android.phone   : Older Samsung variant
      - com.samsung.android.dialer  : Samsung dialer — detected to know popup was dismissed
      - com.google.android.dialer   : Pixel/stock dialer — same role
      - com.huawei.phone            : Huawei telephony
      - android                     : System-level window fallback

    NOTE: CALL_PHONE permission is NOT used. The dialer is opened via ACTION_DIAL
    (user manually presses Call). No auto-dial occurs.

    Flags:
      - flagDefault: standard accessibility event delivery
      - flagIncludeNotImportantViews: ensures we see all TextViews inside the dialog,
        not just "important" (focusable) ones — critical for capturing USSD text.
      - flagRetrieveInteractiveWindows: allows rootInActiveWindow access, needed on
        Android 9+ for the fallback node-tree harvest path.
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged|typeWindowContentChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagDefault|flagIncludeNotImportantViews|flagRetrieveInteractiveWindows"
    android:canRetrieveWindowContent="true"
    android:description="@string/accessibility_service_description"
    android:packageNames="com.android.phone,com.google.android.dialer,com.samsung.android.dialer,com.samsung.telephony.phone,com.samsung.android.phone,com.huawei.phone,android"
    android:notificationTimeout="100"
    android:settingsActivity="com.ethiobalance.app.MainActivity" />
